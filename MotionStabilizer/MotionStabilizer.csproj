<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>MotionStabilizer</AssemblyName>
    <RootNamespace>MotionStabilizer</RootNamespace>
    <Version>1.0.0</Version>
    <Company>3D Motion Stabilizer</Company>
    <Product>Motion Stabilizer</Product>
    <Description>Safe, zero-intrusion visual stabilization overlay for 3D game motion sickness relief</Description>
  </PropertyGroup>

</Project>
