    <sys:String x:Key="About_Feature1">✓ Pure external desktop overlay — no DLL injection</sys:String>
    <sys:String x:Key="About_Feature2">✓ Safe under all anti-cheat systems (Vanguard, EAC, BattlEye)</sys:String>
    <sys:String x:Key="About_Feature3">✓ No game files modified, no memory access</sys:String>
    <sys:String x:Key="About_Author">Author: shsr07</sys:String>
