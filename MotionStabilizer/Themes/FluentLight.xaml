<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════ Color Palette (Fluent Light) ═══════════════ -->

    <Color x:Key="BgDark">#F3F3F3</Color>
    <Color x:Key="BgDarker">#E8E8E8</Color>
    <Color x:Key="BgCard">#FFFFFF</Color>
    <Color x:Key="BgCardHover">#F0F0F0</Color>
    <Color x:Key="BgAccent">#0078D4</Color>
    <Color x:Key="BgAccentHover">#1A86D9</Color>
    <Color x:Key="TextPrimary">#1A1A1A</Color>
    <Color x:Key="TextSecondary">#6E6E6E</Color>
    <Color x:Key="BorderSubtle">#D1D1D1</Color>
    <Color x:Key="AccentGreen">#00B853</Color>
    <Color x:Key="AccentRed">#D93B3B</Color>
    <Color x:Key="AccentYellow">#C99700</Color>

    <SolidColorBrush x:Key="BrushBgDark" Color="{StaticResource BgDark}" />
    <SolidColorBrush x:Key="BrushBgDarker" Color="{StaticResource BgDarker}" />
    <SolidColorBrush x:Key="BrushBgCard" Color="{StaticResource BgCard}" />
    <SolidColorBrush x:Key="BrushBgCardHover" Color="{StaticResource BgCardHover}" />
    <SolidColorBrush x:Key="BrushBgAccent" Color="{StaticResource BgAccent}" />
    <SolidColorBrush x:Key="BrushBgAccentHover" Color="{StaticResource BgAccentHover}" />
    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="BrushBorderSubtle" Color="{StaticResource BorderSubtle}" />
    <SolidColorBrush x:Key="BrushAccentGreen" Color="{StaticResource AccentGreen}" />
    <SolidColorBrush x:Key="BrushAccentRed" Color="{StaticResource AccentRed}" />
    <SolidColorBrush x:Key="BrushAccentYellow" Color="{StaticResource AccentYellow}" />

    <!-- ═══════════════ Black Text Outline Effect ═══════════════ -->
    <DropShadowEffect x:Key="BlackTextOutline"
                      Color="Black"
                      BlurRadius="3"
                      ShadowDepth="0"
                      Opacity="1" />

    <!-- ═══════════════ Base Styles ═══════════════ -->

    <Style TargetType="Window" x:Key="MainWindowStyle">
        <Setter Property="Background" Value="{StaticResource BrushBgDark}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Microsoft YaHei UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="WindowStyle" Value="None" />
        <Setter Property="AllowsTransparency" Value="True" />
        <Setter Property="ResizeMode" Value="CanResize" />
    </Style>

    <Style TargetType="Page">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Microsoft YaHei UI" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- ═══════════════ TextBlock ═══════════════ -->

    <Style TargetType="TextBlock" x:Key="PageTitle">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <Style TargetType="TextBlock" x:Key="CardTitle">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style TargetType="TextBlock" x:Key="FieldLabel">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,12,0" />
    </Style>

    <!-- ═══════════════ Card (Border) ═══════════════ -->

    <Style TargetType="Border" x:Key="SettingsCard">
        <Setter Property="Background" Value="{StaticResource BrushBgCard}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20,16" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <!-- ═══════════════ Toggle Switch ═══════════════ -->

    <Style TargetType="CheckBox" x:Key="ToggleSwitch">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="toggleBorder"
                                Width="44" Height="24"
                                CornerRadius="12"
                                Background="#C0C0C0"
                                BorderThickness="0">
                            <Border x:Name="toggleDot"
                                    Width="18" Height="18"
                                    CornerRadius="9"
                                    Background="White"
                                    HorizontalAlignment="Left"
                                    Margin="3,0,0,0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="dotTransform" X="0" />
                                </Border.RenderTransform>
                            </Border>
                        </Border>
                        <ContentPresenter Margin="12,0,0,0"
                                          VerticalAlignment="Center"
                                          TextBlock.Foreground="{StaticResource BrushTextPrimary}" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="toggleBorder" Property="Background" Value="{StaticResource BrushBgAccent}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="dotTransform"
                                                         Storyboard.TargetProperty="X"
                                                         To="20" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="dotTransform"
                                                         Storyboard.TargetProperty="X"
                                                         To="0" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════ Slider ═══════════════ -->

    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource BrushBgAccent}" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <Border Height="4" CornerRadius="2" Background="{StaticResource BrushBorderSubtle}" VerticalAlignment="Center" />
                        <Track x:Name="PART_Track" VerticalAlignment="Center">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{x:Null}">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="4" CornerRadius="2" Background="{StaticResource BrushBgAccent}" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{x:Null}">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="4" CornerRadius="2" Background="Transparent" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Width="16" Height="16" CornerRadius="8"
                                                    Background="White"
                                                    BorderBrush="{StaticResource BrushBgAccent}"
                                                    BorderThickness="2" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════ ComboBox ═══════════════ -->

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource BrushBgCard}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Microsoft YaHei UI" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Height" Value="36" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- ═══════════════ Button ═══════════════ -->

    <Style TargetType="Button" x:Key="PrimaryButton">
        <Setter Property="Background" Value="{StaticResource BrushBgAccent}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="btnBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource BrushBgAccentHover}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="SecondaryButton">
        <Setter Property="Background" Value="{StaticResource BrushBgCard}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="btnBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource BrushBgCardHover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Shape selection button -->
    <Style TargetType="Button" x:Key="ShapeButton">
        <Setter Property="Background" Value="{StaticResource BrushBgCard}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Width" Value="80" />
        <Setter Property="Height" Value="72" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="btnBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ContentPresenter HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource BrushBgCardHover}" />
                        </Trigger>
                        <Trigger Property="Tag" Value="Selected">
                            <Setter TargetName="btnBorder" Property="BorderBrush" Value="{StaticResource BrushBgAccent}" />
                            <Setter TargetName="btnBorder" Property="BorderThickness" Value="2" />
                            <Setter TargetName="btnBorder" Property="Background" Value="#E3F0FB" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Color swatch button -->
    <Style TargetType="Button" x:Key="ColorSwatchButton">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="swatchBorder"
                            Width="36" Height="36"
                            CornerRadius="18"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource BrushBorderSubtle}"
                            BorderThickness="2" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="Tag" Value="Selected">
                            <Setter TargetName="swatchBorder" Property="BorderBrush" Value="{StaticResource BrushTextPrimary}" />
                            <Setter TargetName="swatchBorder" Property="BorderThickness" Value="3" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════ Sidebar Nav Button ═══════════════ -->

    <Style TargetType="RadioButton" x:Key="NavButton">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Height" Value="48" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="navBorder"
                            Background="Transparent"
                            CornerRadius="6"
                            Padding="16,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="navIcon"
                                       Text="{TemplateBinding Tag}"
                                       FontSize="18"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center" />
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="navBorder" Property="Background" Value="{StaticResource BrushBgCardHover}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="navBorder" Property="Background" Value="{StaticResource BrushBgCard}" />
                            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════ TextBox ═══════════════ -->

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BrushBgCard}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Microsoft YaHei UI" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CaretBrush" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="tbBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="tbBorder" Property="BorderBrush" Value="{StaticResource BrushBgAccent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════ ComboBoxItem ═══════════════ -->

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{StaticResource BrushBgCard}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Microsoft YaHei UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="TextBlock.Effect" Value="{StaticResource BlackTextOutline}" />
    </Style>

</ResourceDictionary>
