<Page x:Class="MotionStabilizer.Views.ClockPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
        <StackPanel Margin="24,0,24,24">

            <!-- Title -->
            <TextBlock Text="{DynamicResource Clock_Title}" Style="{StaticResource PageTitle}" />
            <TextBlock Text="{DynamicResource Clock_Desc}" Foreground="{StaticResource BrushTextSecondary}" FontSize="13"
                       Margin="0,0,0,24" TextWrapping="Wrap" />

            <!-- ═══════ Toggle Switch ═══════ -->
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="ToggleClock" Style="{StaticResource ToggleSwitch}"
                              Content="{DynamicResource Nav_Clock}"
                              Checked="ToggleClock_Changed"
                              Unchecked="ToggleClock_Changed" />
                    <TextBlock x:Name="HotkeyLabel" Text="" Foreground="{StaticResource BrushTextSecondary}" FontSize="12"
                               VerticalAlignment="Center" Margin="24,0,0,0" />
                </StackPanel>
            </Border>

            <!-- ═══════ Time Format ═══════ -->
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Clock_FormatCard}" Style="{StaticResource CardTitle}" />
                    <StackPanel Orientation="Vertical">
                        <RadioButton x:Name="RbFormat1" Content="HH:mm" Margin="0,0,0,8"
                                     Foreground="{StaticResource BrushTextPrimary}" Checked="Format_Changed" />
                        <RadioButton x:Name="RbFormat2" Content="HH:mm:ss" Margin="0,0,0,8"
                                     Foreground="{StaticResource BrushTextPrimary}" Checked="Format_Changed" />
                        <RadioButton x:Name="RbFormat3" Content="am/pm h:mm" Margin="0,0,0,8"
                                     Foreground="{StaticResource BrushTextPrimary}" Checked="Format_Changed" />
                        <TextBlock x:Name="PreviewLabel" Text="22:32" FontFamily="Consolas" FontSize="22"
                                   Foreground="#00E676" Margin="8,8,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══════ Font Style ═══════ -->
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Clock_FontCard}" Style="{StaticResource CardTitle}" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="{DynamicResource Clock_FontFamily}" Style="{StaticResource FieldLabel}" Width="80" />
                        <ComboBox x:Name="CbFontFamily" Width="200" Height="32"
                                  SelectionChanged="FontFamily_Changed">
                            <ComboBoxItem Content="Outline" />
                            <ComboBoxItem Content="Consolas" />
                            <ComboBoxItem Content="Segoe UI" />
                            <ComboBoxItem Content="Microsoft YaHei UI" />
                            <ComboBoxItem Content="Courier New" />
                            <ComboBoxItem Content="Arial" />
                            <ComboBoxItem Content="Tahoma" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="{DynamicResource Clock_FontSize}" Style="{StaticResource FieldLabel}" Width="80" />
                        <Slider x:Name="SliderFontSize" Width="300" Minimum="10" Maximum="72"
                                ValueChanged="FontSize_Changed" />
                        <TextBlock x:Name="FontSizeLabel" Text="24" Foreground="{StaticResource BrushTextPrimary}" FontSize="13"
                                   VerticalAlignment="Center" Margin="12,0,0,0" Width="40" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource Color}" Style="{StaticResource FieldLabel}" Width="80" />
                        <Button x:Name="BtnColor" Style="{StaticResource SecondaryButton}" Width="80" Height="32"
                                Background="White" Click="Color_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══════ Position ═══════ -->
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Clock_PositionCard}" Style="{StaticResource CardTitle}" />
                    <TextBlock Text="{DynamicResource Clock_PositionHint}"
                               Foreground="{StaticResource BrushTextSecondary}" FontSize="12" TextWrapping="Wrap"
                               Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="X" Style="{StaticResource FieldLabel}" Width="60" />
                        <TextBox x:Name="TxtPosX" Width="80" Margin="0,0,24,0"
                                 TextChanged="PosX_Changed" />
                        <TextBlock Text="Y" Style="{StaticResource FieldLabel}" Width="60" />
                        <TextBox x:Name="TxtPosY" Width="80" Margin="0,0,24,0"
                                 TextChanged="PosY_Changed" />
                    </StackPanel>
                    <Button x:Name="BtnDrag" Style="{StaticResource SecondaryButton}"
                            Content="{DynamicResource Clock_UnlockDrag}"
                            Click="Drag_Click" />
                </StackPanel>
            </Border>

            <!-- ═══════ Opacity ═══════ -->
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Opacity}" Style="{StaticResource CardTitle}" />
                    <StackPanel Orientation="Horizontal">
                        <Slider x:Name="SliderOpacity" Width="380" Minimum="0" Maximum="100"
                                ValueChanged="Opacity_Changed" />
                        <TextBlock x:Name="OpacityLabel" Text="100%" Foreground="{StaticResource BrushTextPrimary}" FontSize="13"
                                   VerticalAlignment="Center" Margin="12,0,0,0" Width="40" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
